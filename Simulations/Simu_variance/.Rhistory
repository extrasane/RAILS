# â”€â”€ Panel (a): Bar plot with mean estimate + 3 types of CI (start from 8k) â”€â”€
# Empirical SD based CI for RAILS only
ci_emp <- do.call(rbind, lapply(seq_along(out_mean_list), function(i) {
df <- out_mean_list[[i]]
df$method <- rownames(df)
df$scenario <- i
df[df$method == "ps_vs_stepwise_twoway_rake",
c("method", "scenario", "mean", "Emp SD", "Avg SD")]
})) %>%
mutate(method = "RAILS")
# Mean SE from RAILS-Stack (Varcor)
varcor_se <- do.call(rbind, lapply(seq_along(filenames), function(i) {
out <- readRDS(paste0(filenames[i], ".RData"))
data.frame(
scenario    = i,
mean_varcor = out$out_varcor["mu_hat"],
se_stack    = out$out_varcor["se_full"],
check.names = FALSE
)
}))
# Combine into panel (a) data â€” filter scenario <= 5 (8k onward, excluding 5k)
panel_a_df <- ci_emp %>%
filter(scenario <= 5) %>%
left_join(varcor_se, by = "scenario") %>%
mutate(
scenario    = factor(scenario, levels = 5:1),
emp_lower   = mean - 1.96 * `Emp SD`,
emp_upper   = mean + 1.96 * `Emp SD`,
naive_lower = mean - 1.96 * `Avg SD`,
naive_upper = mean + 1.96 * `Avg SD`,
stack_lower = mean - 1.96 * se_stack,
stack_upper = mean + 1.96 * se_stack
) %>%
pivot_longer(
cols          = c(emp_lower, emp_upper, naive_lower, naive_upper,
stack_lower, stack_upper),
names_to      = c("ci_type", ".value"),
names_pattern = "(.*)_(lower|upper)"
) %>%
mutate(ci_type = recode(ci_type,
"emp"   = "Empirical SD",
"naive" = "Mean SE (Naive)",
"stack" = "Mean SE (Stack)"
))
pa <- ggplot(panel_a_df, aes(x = scenario, y = mean)) +
geom_point(size = 2, color = "steelblue") +
geom_errorbar(aes(ymin = lower, ymax = upper, color = ci_type),
width = 0.25, linewidth = 0.8,
position = position_dodge(width = 0.5)) +
geom_hline(yintercept = true_value, linetype = "dashed", color = "black") +
scale_x_discrete(labels = size_labels_fmt[2:6]) +
coord_cartesian(ylim = c(
min(panel_a_df$lower, na.rm = TRUE) * 0.995,
max(panel_a_df$upper, na.rm = TRUE) * 1.005
)) +
scale_color_manual(values = c(
"Empirical SD"    = "#E41A1C",
"Mean SE (Naive)" = "#377EB8",
"Mean SE (Stack)" = "#4DAF4A"
)) +
labs(x = "Sample Size", y = "Mean Estimate", color = "CI Type",
title = "(a) Mean Estimate with 95% CI") +
theme_bw() +
theme(legend.position = "bottom")
# â”€â”€ Shared labels and colors for panels (b) and (c) â”€â”€
bc_recode <- c(
"RAILS"         = "RAILS (Naive Var)",
"RAILS_Varcor"  = "RAILS (Stacked Var)",
"True_RAILS"    = "True RAILS"
)
bc_colors <- c(
"RAILS (Naive Var)"   = "#4DAF4A",
"RAILS (Stacked Var)" = "#00BCD4",
"True RAILS"          = "#E41A1C"
)
# â”€â”€ Panel (b): Nominal Coverage â”€â”€
nominal_df <- bind_rows(out_mean_df, varcor_rows) %>%
filter(method %in% c("RAILS", "RAILS_Varcor", "True_RAILS"),
scenario <= 5) %>%
mutate(
scenario = factor(scenario, levels = 5:1),
method   = recode(method, !!!bc_recode)
)
pb <- ggplot(nominal_df, aes(x = scenario, y = `Nominal Coverage`,
color = method, group = method)) +
geom_line() +
geom_point() +
geom_hline(yintercept = 0.95, linetype = "dashed", color = "black") +
scale_x_discrete(labels = size_labels_fmt[2:6]) +
scale_color_manual(values = bc_colors) +
labs(x = "Sample Size", y = "Coverage", color = "Method",
title = "(b) Nominal Coverage") +
theme_bw() +
theme(legend.position = "none")
# â”€â”€ Panel (c): Oracle Coverage â”€â”€
oracle_df <- bind_rows(out_mean_df, varcor_rows) %>%
filter(method %in% c("RAILS", "RAILS_Varcor", "True_RAILS"),
scenario <= 5) %>%
mutate(
scenario = factor(scenario, levels = 5:1),
method   = recode(method, !!!bc_recode)
)
pc <- ggplot(oracle_df, aes(x = scenario, y = `Oracle Coverage`,
color = method, group = method)) +
geom_line() +
geom_point() +
geom_hline(yintercept = 0.95, linetype = "dashed", color = "black") +
scale_x_discrete(labels = size_labels_fmt[2:6]) +
scale_color_manual(values = bc_colors) +
labs(x = "Sample Size", y = "Coverage", color = "Method",
title = "(c) Oracle Coverage") +
theme_bw() +
theme(legend.position = "none")
# â”€â”€ Extract legend from panel (a) â”€â”€
legend_a <- cowplot::get_plot_component(pa, "guide-box-bottom",
return_all = FALSE)
# â”€â”€ Extract shared legend for panels (b) and (c) â”€â”€
legend_plot <- ggplot(nominal_df,
aes(x = scenario, y = `Nominal Coverage`,
color = method, group = method)) +
geom_line() +
geom_point() +
scale_color_manual(
values = bc_colors,
guide  = guide_legend(
title          = "Method",
title.position = "top",
nrow           = 1
)
) +
theme_bw() +
theme(
legend.position  = "bottom",
legend.text      = element_text(size = 10),
legend.title     = element_text(size = 11),
legend.direction = "horizontal"
)
legend_bc <- cowplot::get_plot_component(legend_plot, "guide-box-bottom",
return_all = FALSE)
# â”€â”€ Center legend_bc under panels (b) and (c) â”€â”€
legend_bc_centered <- cowplot::plot_grid(
NULL, legend_bc, NULL,
ncol       = 3,
rel_widths = c(0.5, 2, 0.5)
)
# â”€â”€ Bottom row: legend_a under panel (a), legend_bc centered under (b)+(c) â”€â”€
bottom_row <- cowplot::plot_grid(
legend_a,
legend_bc_centered,
ncol       = 2,
rel_widths = c(1.2, 2)
)
# â”€â”€ Top row: three panels â”€â”€
pa_noleg <- pa + theme(legend.position = "none")
top_row <- cowplot::plot_grid(
pa_noleg, pb, pc,
ncol       = 3,
rel_widths = c(1.2, 1, 1),
align      = "h",
axis       = "tb"
)
# â”€â”€ Combine top and bottom rows â”€â”€
p_combined <- cowplot::plot_grid(
top_row,
bottom_row,
ncol        = 1,
rel_heights = c(1, 0.12)
)
p_combined
ggsave("Figure_ThreePanel.png", plot = p_combined,
dpi = 300, width = 14, height = 6, units = "in")
# â”€â”€ Build CI data for each method and SD type â”€â”€
# --- Original RAILS: Empirical, Simplified, Stacked ---
ci_orig <- do.call(rbind, lapply(seq_along(out_mean_list), function(i) {
df <- out_mean_list[[i]]
df$method <- rownames(df)
df$scenario <- i
df[df$method == "ps_vs_stepwise_twoway_rake",
c("method", "scenario", "mean", "Emp SD", "Avg SD")]
})) %>%
mutate(method = "Original_RAILS") %>%
left_join(
do.call(rbind, lapply(seq_along(filenames), function(i) {
out <- readRDS(paste0(filenames[i], ".RData"))
data.frame(scenario = i, se_stack = out$out_varcor["se_full"], check.names = FALSE)
})),
by = "scenario"
) %>%
mutate(
emp_lower   = mean - 1.96 * `Emp SD`,  emp_upper   = mean + 1.96 * `Emp SD`,
naive_lower = mean - 1.96 * `Avg SD`,  naive_upper = mean + 1.96 * `Avg SD`,
stack_lower = mean - 1.96 * se_stack,  stack_upper = mean + 1.96 * se_stack
) %>%
pivot_longer(
cols = c(emp_lower, emp_upper, naive_lower, naive_upper, stack_lower, stack_upper),
names_to = c("ci_type", ".value"), names_pattern = "(.*)_(lower|upper)"
) %>%
mutate(ci_type = recode(ci_type,
"emp" = "Empirical SD", "naive" = "Simplified SD", "stack" = "Stacked SD"))
# --- Oracle RAILS: Empirical, Simplified, Stacked ---
ci_oracle <- do.call(rbind, lapply(seq_along(out_mean_list), function(i) {
df <- out_mean_list[[i]]
df$method <- rownames(df)
df$scenario <- i
df[df$method == "oracle_rails",
c("method", "scenario", "mean", "Emp SD", "Avg SD")]
})) %>%
mutate(method = "Oracle_RAILS") %>%
left_join(
do.call(rbind, lapply(seq_along(filenames), function(i) {
out <- readRDS(paste0(filenames[i], ".RData"))
data.frame(scenario = i, se_stack = out$out_varcor_oracle["se_full"], check.names = FALSE)
})),
by = "scenario"
) %>%
mutate(
emp_lower   = mean - 1.96 * `Emp SD`,  emp_upper   = mean + 1.96 * `Emp SD`,
naive_lower = mean - 1.96 * `Avg SD`,  naive_upper = mean + 1.96 * `Avg SD`,
stack_lower = mean - 1.96 * se_stack,  stack_upper = mean + 1.96 * se_stack
) %>%
pivot_longer(
cols = c(emp_lower, emp_upper, naive_lower, naive_upper, stack_lower, stack_upper),
names_to = c("ci_type", ".value"), names_pattern = "(.*)_(lower|upper)"
) %>%
mutate(ci_type = recode(ci_type,
"emp" = "Empirical SD", "naive" = "Simplified SD", "stack" = "Stacked SD"))
# --- Cal_1: Empirical, Simplified, Stacked (Survey SD removed) ---
ci_svy <- do.call(rbind, lapply(seq_along(out_mean_list), function(i) {
df <- out_mean_list[[i]]
df$method <- rownames(df)
df$scenario <- i
df[df$method == "svy_oneway_rake",
c("method", "scenario", "mean", "Emp SD", "Avg SD")]
})) %>%
mutate(method = "Cal_1") %>%
left_join(
do.call(rbind, lapply(seq_along(filenames), function(i) {
out <- readRDS(paste0(filenames[i], ".RData"))
data.frame(scenario = i, se_stack = out$out_varcor_svy["se_full"], check.names = FALSE)
})),
by = "scenario"
) %>%
mutate(
emp_lower   = mean - 1.96 * `Emp SD`,  emp_upper   = mean + 1.96 * `Emp SD`,
naive_lower = mean - 1.96 * `Avg SD`,  naive_upper = mean + 1.96 * `Avg SD`,
stack_lower = mean - 1.96 * se_stack,  stack_upper = mean + 1.96 * se_stack
) %>%
pivot_longer(
cols = c(emp_lower, emp_upper, naive_lower, naive_upper,
stack_lower, stack_upper),
names_to = c("ci_type", ".value"), names_pattern = "(.*)_(lower|upper)"
) %>%
mutate(ci_type = recode(ci_type,
"emp" = "Empirical SD", "naive" = "Simplified SD",
"stack" = "Stacked SD"))
# â”€â”€ Combine â€” no NAs, each method only carries its own CI types â”€â”€
ci_all <- bind_rows(ci_orig, ci_oracle, ci_svy) %>%
mutate(
scenario = factor(scenario, levels = 6:1),
method   = factor(method, levels = c("Original_RAILS", "Oracle_RAILS", "Cal_1")),
ci_type  = factor(ci_type, levels = c("Empirical SD", "Simplified SD", "Stacked SD"))
)
ci_colors <- c(
"Empirical SD"  = "#E41A1C",
"Simplified SD" = "#377EB8",
"Stacked SD"    = "#4DAF4A"
)
# â”€â”€ Plot: dodged point + bar per CI type â”€â”€
p_ci <- ggplot(ci_all, aes(x = scenario, y = mean, color = ci_type, group = ci_type)) +
geom_point(size = 2, position = position_dodge(width = 0.6)) +
geom_errorbar(aes(ymin = lower, ymax = upper),
width = 0.3, linewidth = 0.7,
position = position_dodge(width = 0.6)) +
geom_hline(yintercept = true_value, linetype = "dashed", color = "black") +
facet_grid(method ~ ., scales = "free_y") +
scale_x_discrete(labels = size_labels_fmt) +
scale_color_manual(values = ci_colors, drop = FALSE) +
labs(x = "Sample Size", y = "Mean Estimate", color = "CI Type",
title = "95% Confidence Intervals by Method and SD Type") +
theme_bw() +
theme(legend.position = "bottom",
strip.text.y    = element_text(size = 11, face = "bold"))
ggplotly(p_ci)
sessionInfo()`
